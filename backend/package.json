{
  "name": "@audio-tab-capture/backend",
  "version": "1.0.0",
  "description": "Backend API for audio tab capture with WebSocket support",
  "main": "dist/server.js",
  "scripts": {
    "dev": "vite-node src/server.ts --watch",
    "build": "vite build",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@audio-tab-capture/shared": "file:../shared",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "vite": "^5.1.1",
    "vite-node": "^1.2.2"
  },
  "keywords": [
    "express",
    "websocket",
    "audio",
    "api",
    "backend"
  ]
}