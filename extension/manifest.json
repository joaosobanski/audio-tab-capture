{
  "manifest_version": 3,
  "name": "Audio Tab Capture",
  "version": "1.0.0",
  "description": "Capture audio from browser tabs and stream to backend in real-time",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "desktopCapture"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "https://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.iife.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.iife.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Audio Tab Capture",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.iife.js"],
      "matches": ["<all_urls>"]
    }
  ]
}