{
  "name": "audio-tab-capture",
  "version": "1.0.0",
  "description": "Real-time audio tab capture streaming system",
  "private": true,
  "workspaces": [
    "extension",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:extension\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:extension": "npm run dev --workspace=extension",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=backend",
    "build:extension": "npm run build --workspace=extension",
    "build:shared": "npm run build --workspace=shared",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.js,.tsx,.jsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}