{
  "name": "audio-tab-capture",
  "version": "1.0.0",
  "description": "Complete streaming project for capturing audio from browser tabs and streaming to backend in real-time",
  "private": true,
  "workspaces": [
    "extension",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:extension\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:extension": "npm run dev --workspace=extension",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=backend",
    "build:extension": "npm run build --workspace=extension",
    "build:shared": "npm run build --workspace=shared",
    "type-check": "npm run type-check --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "install:all": "npm install && npm install --workspaces"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "audio",
    "browser-extension",
    "streaming",
    "websocket",
    "chrome-extension",
    "audio-capture"
  ],
  "author": "Audio Tab Capture Team",
  "license": "MIT"
}